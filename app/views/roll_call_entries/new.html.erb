<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h1 class="mb-4 text-center">Feuille d'appel</h1>

      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <p class="text-muted text-center mb-4">
        Merci de renseigner votre prénom et votre nom pour enregistrer votre présence.
      </p>

      <%= form_with model: @roll_call_entry, url: roll_call_entries_path, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :first_name, "Prénom", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control", required: true, autocomplete: "given-name" %>
        </div>

        <div class="mb-3">
          <%= f.label :last_name, "Nom", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control", required: true, autocomplete: "family-name" %>
        </div>

        <div class="d-grid">
          <%= f.submit "Je suis présent(e)", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

