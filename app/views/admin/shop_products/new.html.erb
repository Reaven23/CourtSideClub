<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Nouveau produit</h1>
    <%= link_to "← Retour aux produits", admin_shop_products_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <%= form_with model: @product, url: admin_shop_products_path, method: :post, class: "needs-validation" do |f| %>
    <div class="row g-4">
      <div class="col-md-8">
        <div class="card mb-4">
          <div class="card-header"><h5 class="mb-0">Informations générales</h5></div>
          <div class="card-body">
            <div class="mb-3">
              <%= f.label :name, "Nom du produit", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <%= f.label :description, "Description", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 3 %>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :price_cents, "Prix (en centimes)", class: "form-label" %>
                <%= f.number_field :price_cents, class: "form-control", min: 0, required: true, placeholder: "2000 = 20€" %>
                <small class="text-muted">Ex: 2000 pour 20€, 4900 pour 49€</small>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :product_type, "Type", class: "form-label" %>
                <%= f.select :product_type, [["Achat unique", "one_time"], ["Abonnement", "subscription"]], {}, class: "form-select", required: true, id: "product_type_select" %>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :stripe_product_id, "Stripe Product ID", class: "form-label" %>
                <%= f.text_field :stripe_product_id, class: "form-control", placeholder: "prod_..." %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :stripe_price_id, "Stripe Price ID", class: "form-label" %>
                <%= f.text_field :stripe_price_id, class: "form-control", placeholder: "price_..." %>
              </div>
            </div>
            <div class="form-check form-switch">
              <%= f.check_box :active, class: "form-check-input", role: "switch", checked: true %>
              <%= f.label :active, "Produit actif", class: "form-check-label" %>
            </div>
          </div>
        </div>

        <div class="card" id="sizes-card">
          <div class="card-header"><h5 class="mb-0">Stock par taille (produit physique)</h5></div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Taille</th>
                    <th>Stock initial</th>
                  </tr>
                </thead>
                <tbody>
                  <% %w[S M L XL XXL].each do |size| %>
                    <tr>
                      <td><strong><%= size %></strong></td>
                      <td style="max-width: 120px;">
                        <input type="number" name="sizes[<%= size %>]" value="0" min="0" class="form-control form-control-sm">
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <%= f.submit "Créer le produit", class: "btn btn-primary w-100" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
