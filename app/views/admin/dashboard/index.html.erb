<div class="container py-4">
  <h1 class="h3 mb-4">Dashboard Admin</h1>

  <%= turbo_frame_tag 'admin_content' do %>
    <ul class="nav nav-pills gap-2 mb-4">
      <li class="nav-item"><%= link_to 'Utilisateurs', admin_dashboard_path(tab: 'users'), class: "nav-link #{'active' if @tab == 'users'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Articles', admin_dashboard_path(tab: 'articles'), class: "nav-link #{'active' if @tab == 'articles'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Jeux', admin_dashboard_path(tab: 'games'), class: "nav-link #{'active' if @tab == 'games'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Récompenses', admin_dashboard_path(tab: 'rewards'), class: "nav-link #{'active' if @tab == 'rewards'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item">
        <%= link_to admin_dashboard_path(tab: 'notifications'), class: "nav-link #{'active' if @tab == 'notifications'}", data: { turbo_frame: 'admin_content' } do %>
          Notifications
          <% if @unread_notifications_count > 0 %>
            <span class="badge bg-danger ms-1"><%= @unread_notifications_count %></span>
          <% end %>
        <% end %>
      </li>
      <li class="nav-item"><%= link_to 'Votes', admin_dashboard_path(tab: 'votes'), class: "nav-link #{'active' if @tab == 'votes'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Joueurs', admin_dashboard_path(tab: 'players'), class: "nav-link #{'active' if @tab == 'players'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Boutique', admin_dashboard_path(tab: 'shop'), class: "nav-link #{'active' if @tab == 'shop'}", data: { turbo_frame: 'admin_content' } %></li>
      <li class="nav-item"><%= link_to 'Commandes', admin_dashboard_path(tab: 'orders'), class: "nav-link #{'active' if @tab == 'orders'}", data: { turbo_frame: 'admin_content' } %></li>
    </ul>

    <% case @tab
       when 'users' %>
      <%= render partial: 'admin/dashboard/users', locals: { users: @users } %>
    <% when 'articles' %>
      <%= render partial: 'admin/dashboard/articles', locals: { draft_articles: @draft_articles, published_articles: @published_articles } %>
    <% when 'games' %>
      <%= render partial: 'admin/dashboard/games', locals: { quiz_games: @quiz_games, new_quiz_game: @new_quiz_game } %>
    <% when 'rewards' %>
      <%= render partial: 'admin/dashboard/rewards' %>
    <% when 'notifications' %>
      <%= render partial: 'admin/dashboard/notifications' %>
    <% when 'votes' %>
      <%= render partial: 'admin/dashboard/votes', locals: { vote_campaigns: @vote_campaigns } %>
    <% when 'players' %>
      <%= render partial: 'admin/dashboard/players', locals: { players: @players } %>
    <% when 'shop' %>
      <%= render partial: 'admin/dashboard/shop', locals: { products: @products } %>
    <% when 'orders' %>
      <%= render partial: 'admin/dashboard/orders', locals: { orders: @orders } %>
    <% end %>
  <% end %>
</div>
